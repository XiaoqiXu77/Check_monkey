function ttl = task_title(taskName)
    switch taskName
        case 'speed'
            ttl = 'Progress Rate';
        case 'speed_est'
            ttl = 'Estimated progress Rate';
        case 'gauge_size'
            ttl = 'Gauge Size';
        case 'gs_est'
            ttl = 'Estimated Gauge Size Decoding';
        case 'pre_gs'
            ttl = 'Previous gauge size';
        case 'wl'
            ttl = 'Work length';
        case 'gauge_diff'
            ttl = 'Gauge Diff Decoding';
        case 'choice'
            ttl = 'Choice Decoding';
        otherwise
            ttl = taskName;
    end
end
